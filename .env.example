# Game Script — root environment (read by backend/config.py)
# Copy to .env and fill in. The pipeline runs with NONE of these set (sample mode).

# Season/week — update weekly
CURRENT_SEASON=2025
CURRENT_WEEK=1

# Force sample data: auto (default) | true | false
SAMPLE_MODE=auto

# AI
ANTHROPIC_API_KEY=

# Data sources (all free tiers)
ODDS_API_KEY=
APIFY_API_TOKEN=
OPENWEATHER_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from your Stripe dashboard (used by /api/checkout + webhook tier mapping)
STRIPE_PRICE_SHARP_MONTHLY=price_SHARP_MONTHLY
STRIPE_PRICE_SHARP_ANNUAL=price_SHARP_ANNUAL
STRIPE_PRICE_COORD_MONTHLY=price_COORD_MONTHLY
STRIPE_PRICE_COORD_ANNUAL=price_COORD_ANNUAL
STRIPE_PRICE_CREATOR=price_CREATOR_MONTHLY
